{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lensly",
  "version": "2.0.0",
  "identifier": "com.lensly.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "https://lensly.vercel.app",
    "frontendDist": "https://lensly.vercel.app"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lensly",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://api.lensly.app/releases/latest"
      ],
      "dialog": true,
      "pubkey": ""
    }
  }
}
