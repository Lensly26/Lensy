{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "apps/desktop/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "*.exe",
      "*.dmg"
    ],
    "rewrites": [
      {
        "source": "/(.*)",
        "destination": "/index.html"
      }
    ]
  }
}
