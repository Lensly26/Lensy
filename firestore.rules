rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isStaff() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["TRIAL_MODERATOR", "MODERATOR", "ADMIN", "MANAGER", "DEVELOPER", "CO_OWNER", "OWNER"]
      );
    }

    // Usernames collection: used to ensure unique usernames and lookup by username
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
    
    // Users collection: extended profile information
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if isStaff();

      // Friend requests: anyone authenticated can send (create), recipient can read/delete
      match /friendRequests/{requestId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }

    // Typing indicators
    match /typing/{channelId}/typists/{typistId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == typistId;
    }

    // Voice channel presence
    match /voiceChannels/{channelId}/users/{oduserId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == oduserId;
    }

    // Direct messages
    match /dm_channels/{channelId} {
      allow read, write: if request.auth != null;
    }

    // Group DMs
    match /groupDms/{channelId} {
      allow read, write: if request.auth != null;
    }

    // Guild moderation logs
    match /guilds/{guildId}/moderationLogs/{logId} {
      allow read: if isStaff();
      allow create: if request.auth != null;
    }

    // Mod logs (deleted messages)
    match /modLogs/{guildId}/deletedMessages/{msgId} {
      allow read: if isStaff();
      allow create: if request.auth != null;
    }

    match /warnings/{warningId} {
      allow read, write: if isStaff();
    }

    match /reports/{reportId} {
      allow read, write: if isStaff();
      allow create: if request.auth != null;
    }

    match /moderationEvents/{eventId} {
      allow read, write: if isStaff();
    }

    match /tickets/{ticketId} {
      allow read, write: if isStaff();
      allow create: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if isStaff() || (request.auth != null && (
          get(/databases/$(database)/documents/tickets/$(ticketId)).data.authorId == request.auth.uid ||
          get(/databases/$(database)/documents/tickets/$(ticketId)).data.authorId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username
        ));
      }
    }

    match /system/{document} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /mail/{document} {
      allow create: if isStaff();
      allow read, update, delete: if false; // Only extensions or backend should read/update this
    }

    // Settings collection
    match /settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Guilds (Servers)
    match /guilds/{guildId} {
      // Anyone can view servers and their embedded channels for now
      allow read: if true;
      // Any authenticated user can create a server
      allow create: if request.auth != null;
      // Only the owner can update it, or any staff member, or any authenticated user updating members list
      allow update: if (request.auth != null && resource.data.ownerId == request.auth.uid) || 
                     isStaff() || 
                     (request.auth != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']));
      allow delete: if (request.auth != null && resource.data.ownerId == request.auth.uid) || isStaff();
    }

    // Messages within a channel
    match /channels/{channelId}/messages/{messageId} {
      // Anyone can read and write messages for now (since no membership system exists yet)
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.author.id == request.auth.uid;
    }
    
    // Collection group rule for messages (needed for statistics counts)
    match /{path=**}/messages/{messageId} {
      allow read: if request.auth != null;
    }
    
    // Staff applications rules
    match /staffApplications/{appId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isStaff());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isStaff();
    }

    // Voice channel signaling (WebRTC calls)
    match /voiceChannels/{channelId}/calls/{callId} {
      allow read, write: if request.auth != null;
    }
    
    // Deny access to everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
